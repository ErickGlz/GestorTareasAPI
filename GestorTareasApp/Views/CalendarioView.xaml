<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GestorTareasApp.Views.CalendarioView"
              BackgroundColor="#FAF9FE"
             Shell.NavBarIsVisible="False"
             xmlns:models="clr-namespace:GestorTareasApp.Models"
             Title="CalendarioView">
    <Grid RowDefinitions="auto,auto,*,auto">

        <!-- TITULO -->
        <Label Text="Calendario"
               TextColor="Black"
               Grid.Row="0"
               FontAttributes="Bold"
               FontSize="30"
               Margin="8,8,0,8"
               FontFamily="open sans"/>

        <!-- SELECTOR FECHA -->
        <Grid Grid.Row="1"
              Margin="10,0">

            <Border StrokeThickness="1"
                    Stroke="#EAE9EE"
                    BackgroundColor="White"
                    Padding="12,10">

                <Border.Shadow>
                    <Shadow Brush="Black"
                            Offset="0,4"
                            Opacity="0.05"
                            Radius="6"/>
                </Border.Shadow>

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12"/>
                </Border.StrokeShape>

                <Grid ColumnDefinitions="*,Auto">

                    <VerticalStackLayout Grid.Column="0"
                                         Spacing="2">

                        <Label Text="FECHA SELECCIONADA"
                               TextColor="#6970E6"
                               FontSize="11"
                               FontAttributes="Bold"
                               CharacterSpacing="1"
                               FontFamily="open sans"/>

                        <DatePicker Date="{Binding FechaSeleccionada}"
                                    TextColor="Black"
                                    FontSize="16"
                                    FontAttributes="Bold"
                                    FontFamily="open sans"
                                    Format="D"/>

                    </VerticalStackLayout>

                    <Image Grid.Column="1"
                           Source="calendario2.png"
                           HeightRequest="24"
                           WidthRequest="24"
                           VerticalOptions="Center"
                           HorizontalOptions="End"
                           Opacity="0.6"/>

                </Grid>

            </Border>

        </Grid>

        <!-- TAREAS DEL DIA -->
        <CollectionView Grid.Row="2"
                        Margin="0,10,0,0"
                        ItemsSource="{Binding TareasCalendario}">

            <CollectionView.ItemTemplate>

                <DataTemplate x:DataType="models:TareaModel">

                    <Border StrokeThickness=".1"
                            Margin="15,10"
                            Padding="0"
                            BackgroundColor="White"
                            Stroke="#D8DADE">

                        <Border.Shadow>
                            <Shadow Brush="Black"
                                    Offset="5,5"
                                    Opacity="0.1"/>
                        </Border.Shadow>

                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12"/>
                        </Border.StrokeShape>

                        <Grid ColumnDefinitions="auto,*,auto"
                              RowDefinitions="auto,auto,auto"
                              RowSpacing="3"
                              Padding="0,12,12,12">

                            <BoxView Grid.Column="0"
                                     Grid.Row="0"
                                     Grid.RowSpan="3"
                                     WidthRequest="4"
                                     Margin="0,0,12,0">

                                <BoxView.Triggers>

                                    <DataTrigger TargetType="BoxView"
                                                 Binding="{Binding Prioridad}"
                                                 Value="Alta">
                                        <Setter Property="Color"
                                                Value="#FCC0C1"/>
                                    </DataTrigger>

                                    <DataTrigger TargetType="BoxView"
                                                 Binding="{Binding Prioridad}"
                                                 Value="Media">
                                        <Setter Property="Color"
                                                Value="#F8D5AE"/>
                                    </DataTrigger>

                                    <DataTrigger TargetType="BoxView"
                                                 Binding="{Binding Prioridad}"
                                                 Value="Baja">
                                        <Setter Property="Color"
                                                Value="#CCFFCD"/>
                                    </DataTrigger>

                                </BoxView.Triggers>

                            </BoxView>

                            <Label Grid.Column="1"
                                   Grid.Row="0"
                                   Text="{Binding Titulo}"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="Black"/>

                            <Label Grid.Column="1"
                                   Grid.Row="1"
                                   Text="{Binding Descripcion}"
                                   TextColor="#4A4A4A"
                                   FontSize="14"/>

                            <Label Grid.Column="1"
                                   Grid.Row="2"
                                   Text="{Binding FechaCreacion, StringFormat='{0:dd/MM/yyyy}'}"
                                   TextColor="DarkGray"
                                   FontSize="12"/>

                            <Border Grid.Column="2"
                                    Grid.Row="0"
                                    Stroke="Transparent"
                                    Padding="8,3">

                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="6"/>
                                </Border.StrokeShape>

                                <Border.Triggers>

                                    <DataTrigger TargetType="Border"
                                                 Binding="{Binding Prioridad}"
                                                 Value="Alta">
                                        <Setter Property="BackgroundColor"
                                                Value="#FCC0C1"/>
                                    </DataTrigger>

                                    <DataTrigger TargetType="Border"
                                                 Binding="{Binding Prioridad}"
                                                 Value="Media">
                                        <Setter Property="BackgroundColor"
                                                Value="#F8D5AE"/>
                                    </DataTrigger>

                                    <DataTrigger TargetType="Border"
                                                 Binding="{Binding Prioridad}"
                                                 Value="Baja">
                                        <Setter Property="BackgroundColor"
                                                Value="#CCFFCD"/>
                                    </DataTrigger>

                                </Border.Triggers>

                                <Label Text="{Binding Prioridad}"
                                       FontAttributes="Bold"
                                       FontSize="11"
                                       HorizontalTextAlignment="Center">

                                    <Label.Triggers>

                                        <DataTrigger TargetType="Label"
                                                     Binding="{Binding Prioridad}"
                                                     Value="Alta">
                                            <Setter Property="TextColor"
                                                    Value="Red"/>
                                        </DataTrigger>

                                        <DataTrigger TargetType="Label"
                                                     Binding="{Binding Prioridad}"
                                                     Value="Media">
                                            <Setter Property="TextColor"
                                                    Value="DarkOrange"/>
                                        </DataTrigger>

                                        <DataTrigger TargetType="Label"
                                                     Binding="{Binding Prioridad}"
                                                     Value="Baja">
                                            <Setter Property="TextColor"
                                                    Value="DarkGreen"/>
                                        </DataTrigger>

                                    </Label.Triggers>

                                </Label>

                            </Border>

                        </Grid>

                    </Border>

                </DataTemplate>

            </CollectionView.ItemTemplate>

        </CollectionView>

        <!-- MENU -->
        <Border Grid.Row="3"
                StrokeThickness=".1"
                Stroke="#D8DADE"
                Padding="0,0,0,10"
                BackgroundColor="#FDFDFD">

            <Border.Shadow>
                <Shadow Brush="Black"
                        Offset="5,5"
                        Opacity="0.1"/>
            </Border.Shadow>

            <Grid ColumnDefinitions="*,*,*,*,*">

                <Button Grid.Column="0"
                        ImageSource="menu1.png"
                        BackgroundColor="Transparent"/>

                <Button Grid.Column="1"
                        ImageSource="calendario2.png"
                        BackgroundColor="Transparent"
                        Command="{Binding IrCalendarioCommand}"/>

                <Button Grid.Column="2"
                        ImageSource="mas3.png"
                        BackgroundColor="Transparent"
                        Command="{Binding IrNuevaTareaCommand}"/>

                <Button Grid.Column="3"
                        ImageSource="campana1.png"
                        BackgroundColor="Transparent"/>

                <Button Grid.Column="4"
                        ImageSource="ajustes1.png"
                        BackgroundColor="Transparent"/>

            </Grid>

        </Border>

    </Grid>
</ContentPage>