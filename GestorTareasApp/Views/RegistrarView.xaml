<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GestorTareasApp.Views.RegistrarView"
             Title="RegistrarView"  Shell.NavBarIsVisible="False">
    <VerticalStackLayout Margin="25" VerticalOptions="Center">
        <Border BackgroundColor="White" Stroke="Transparent">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="5,5" Opacity="0.06"/>
            </Border.Shadow>

            <Border.StrokeShape>
                <RoundRectangle CornerRadius="16"/>
            </Border.StrokeShape>

            <VerticalStackLayout Padding="10" Background="White">

                <Border Background="#F1F0F5" Stroke="Transparent">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8"/>
                    </Border.StrokeShape>

                    <Grid Padding="7" ColumnDefinitions="*,*">
                        <Button
                        Text="Ingresar"
                        BackgroundColor="Transparent"
                        TextColor="Black"
                        Grid.Column="0"
                        Command="{Binding VolverLoginCommand}"/>

                        <Button
                        Text="Registro"
                        BackgroundColor="#0F1923"
                        TextColor="White"
                        Grid.Column="1"/>
                    </Grid>
                </Border>

                <VerticalStackLayout Margin="0,30,0,0" Spacing="14">
                    <Label
                    Text="Nombre"
                    FontFamily="OpenSansSemibold"
                    FontSize="13"
                    TextColor="Black"/>

                    <Border Background="LightGray" Stroke="Transparent">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8"/>
                        </Border.StrokeShape>

                        <Entry
                        BackgroundColor="White"
                        TextColor="Black"
                         Text="{Binding Nombre}"/>
                    </Border>
                    <Label
                    Text="Correo"
                    FontFamily="OpenSansSemibold"
                    FontSize="13"
                    TextColor="Black"/>

                    <Border Background="LightGray" Stroke="Transparent">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8"/>
                        </Border.StrokeShape>

                        <Entry
                        BackgroundColor="White"
                        TextColor="Black"
                        Text="{Binding Correo}"/>
                    </Border>

                    <Label
                    Text="Contraseña"
                    FontFamily="OpenSansSemibold"
                    FontSize="13"
                    TextColor="Black"
                    Margin="0,10,0,0"/>

                    <Border Background="LightGray" Stroke="Transparent">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8"/>
                        </Border.StrokeShape>

                        <Entry
                        IsPassword="True"
                        BackgroundColor="White"
                        TextColor="Black"
                        Text="{Binding Contrasena}"/>
                    </Border>

                    <Label
                    Text="Confirmar contraseña"
                    FontFamily="OpenSansSemibold"
                    FontSize="13"
                    TextColor="Black"
                    Margin="0,10,0,0"/>

                    <Border Background="LightGray" Stroke="Transparent">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8"/>
                        </Border.StrokeShape>

                        <Entry
                        IsPassword="True"
                        BackgroundColor="White"
                        TextColor="Black"/>
                    </Border>

                    <Button
                    Text="Registrarse"
                    Margin="0,40,0,0"
                    BackgroundColor="#0F1923"
                    TextColor="White"
                    Command="{Binding RegistrarseCommand}"/>

                </VerticalStackLayout>

            </VerticalStackLayout>
        </Border>
    </VerticalStackLayout>

</ContentPage>