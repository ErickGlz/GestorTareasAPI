<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GestorTareasApp.Views.AjustesView"
             Title="AjustesView">
    <Grid RowDefinitions="auto,*,auto">

        <Label Text="Ajustes"
               TextColor="Black"
               Grid.Row="0"
               FontAttributes="Bold"
               FontSize="30"
               Margin="8,8,0,8"
               FontFamily="open sans"/>

        <VerticalStackLayout Grid.Row="1"
                             Margin="0,15,0,0">

            <Grid RowDefinitions="auto,auto">


                <Grid ColumnDefinitions="auto,auto,*,auto"
                      Grid.Row="0"
                      ColumnSpacing="4">

                    <Image Source="campana1.png"
                           HeightRequest="25"
                           Grid.Column="0"
                           Margin="10,0,4,0"
                           VerticalOptions="Center"/>

                    <Label Text="Notificaciones"
                           TextColor="Black"
                           Grid.Column="1"
                           FontSize="20"
                           Margin="0,0,10,0"
                           VerticalTextAlignment="Center"/>

                    <Label Text="Activadas"
                           TextColor="DarkGray"
                           Grid.Column="2"
                           FontSize="16"
                           Margin="0,0,4,0"
                           VerticalTextAlignment="Center"
                           HorizontalTextAlignment="End"/>

                    <Switch Grid.Column="3"
                            Margin="0,0,10,0"
                            OnColor="#6970E6"
                            ThumbColor="LightGray"
                            IsToggled="{Binding NotificacionesActivadas}" />

                </Grid>


                <Grid ColumnDefinitions="auto,*,auto"
                      Grid.Row="1"
                      ColumnSpacing="4"
                      Margin="0,10,0,0">

                    <Image Source="cerrar.png"
                           HeightRequest="25"
                           Grid.Column="0"
                           Margin="10,0,4,0"
                           VerticalOptions="Center"/>

                    <Label Text="Cerrar sesión"
                           TextColor="Black"
                           Grid.Column="1"
                           FontSize="20"
                           Margin="0,0,10,0"
                           VerticalTextAlignment="Center"/>

                    <Button Text=">"
                            Grid.Column="2"
                            TextColor="Black"
                            FontSize="20"
                            BackgroundColor="Transparent"
                            Command="{Binding CerrarSesionCommand}" />

                </Grid>

            </Grid>

        </VerticalStackLayout>

        <!-- Menú inferior -->

        <Border StrokeThickness=".1"
                Stroke="#D8DADE"
                Grid.Row="2"
                VerticalOptions="End"
                Padding="0,0,0,10"
                BackgroundColor="#FDFDFD">

            <Border.Shadow>
                <Shadow Brush="Black"
                        Offset="5,5"
                        Opacity="0.1"/>
            </Border.Shadow>

            <Grid ColumnDefinitions="*,*,*,*,*"
                  VerticalOptions="Center">

                <VerticalStackLayout Grid.Column="0">
                    <Button ImageSource="menu1.png"
                            BackgroundColor="Transparent"
                            MaximumHeightRequest="50"/>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="1">
                    <Button ImageSource="calendario1.png"
                            BackgroundColor="Transparent"
                            MaximumHeightRequest="50"/>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="2">
                    <Button ImageSource="mas3.png"
                            BackgroundColor="Transparent"
                            MaximumHeightRequest="65"/>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="3">
                    <Button ImageSource="campana1.png"
                            BackgroundColor="Transparent"
                            MaximumHeightRequest="50"/>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="4">
                    <Button ImageSource="ajustes2.png"
                            BackgroundColor="Transparent"
                            MaximumHeightRequest="50"/>
                </VerticalStackLayout>

            </Grid>

        </Border>

    </Grid>
</ContentPage>