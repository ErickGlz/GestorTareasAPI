<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GestorTareasApp.Views.VerTareaView"
             Title="VerTareaView"  BackgroundColor="#FAF9FE" Shell.NavBarIsVisible="False">
    <Grid RowDefinitions="*,auto">

        <VerticalStackLayout Margin="0" Spacing="4">

            <Border BackgroundColor="White" Stroke="Transparent">
                <Border.Shadow>
                    <Shadow Brush="Black"
                            Offset="5,5"
                            Opacity="0.06"/>
                </Border.Shadow>

                <Grid ColumnDefinitions="auto,*,auto, auto" Margin="5">

                    <Button Text="&#8249;"
                            Grid.Column="0"
                            FontSize="28"
                            FontAttributes="Bold"
                            TextColor="Black"
                            BackgroundColor="Transparent"
                            Command="{Binding RegresarCommand}" />

                    <Label Text="Detalles"
                           Grid.Column="1"
                           VerticalOptions="Center"
                           TextColor="Black"
                           FontAttributes="Bold"
                           FontSize="22"
                           Margin="10,0,0,0"/>

                    <Button Text="Editar"
                            Grid.Column="3"
                            HeightRequest="30"
                            WidthRequest="70"
                            CornerRadius="10"
                            TextColor="White"
                            BackgroundColor="#6970E6"
                            FontAttributes="Bold"
                            Command="{Binding IrEditarTareaCommand}"
                            CommandParameter="{Binding TareaSeleccionada}" />
                    <Button Text="Eliminar"
                    Grid.Column="2"
                     HeightRequest="30"
                    WidthRequest="70"
                    CornerRadius="10"
                    TextColor="White"
                    BackgroundColor="Red"
                    FontAttributes="Bold"
                    Command="{Binding EliminarTareaSeleccionadaCommand}" />
                </Grid>
            </Border>

            <Label Text="{Binding TareaSeleccionada.Titulo}"
                   TextColor="Black"
                   FontSize="24"
                   HorizontalTextAlignment="Center"
                   FontAttributes="Bold"
                   Margin="12,15,10,0"/>

            <Grid ColumnDefinitions="*,*"
                  Margin="0,5,0,5">

                <StackLayout Grid.Column="0"
                             HorizontalOptions="Center"
                             Spacing="2">

                    <Label Text="Fecha:"
                           TextColor="#6C6C6E"
                           FontSize="14"/>

                    <Label Text="{Binding TareaSeleccionada.FechaCreacion, StringFormat='{0:dd/MM/yyyy}'}"
                           TextColor="#6C6C6E"
                           FontSize="16"/>
                </StackLayout>

                <StackLayout Grid.Column="1"
                             HorizontalOptions="Center"
                             Spacing="2">

                    <Label Text="Prioridad:"
                           TextColor="#6C6C6E"
                           FontSize="14"/>

                    <Label Text="{Binding TareaSeleccionada.Prioridad}"
                           TextColor="#6C6C6E"
                           FontSize="16"/>
                </StackLayout>

            </Grid>

            <BoxView HeightRequest="1"
                     BackgroundColor="#ECEDF4"
                     Margin="5,18,5,10"/>

            <VerticalStackLayout>

                <Label Text="Descripción:"
                       TextColor="#6C6C6E"
                       FontSize="14"
                       Margin="12,5,10,4"/>

                <Label Text="{Binding TareaSeleccionada.Descripcion}"
                       TextColor="Black"
                       FontSize="16"
                       Margin="12,5,10,4"/>

            </VerticalStackLayout>


            <Border StrokeThickness=".1"
                    Margin="15,20,15,10"
                    BackgroundColor="White"
                    Stroke="#D8DADE">

                <Border.Shadow>
                    <Shadow Brush="Black"
                            Offset="5,5"
                            Opacity="0.1"/>
                </Border.Shadow>

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="6"/>
                </Border.StrokeShape>

                <Image HeightRequest="250"
       Aspect="AspectFit">
                    <Image.Source>
                        <FileImageSource File="{Binding TareaSeleccionada.ImagenUrl}" />
                    </Image.Source>
                </Image>
            </Border>

        </VerticalStackLayout>

        <Button Grid.Row="1"
                Text="Completar"
                Command="{Binding CompletarTareaCommand}"
                Margin="25,10,25,10"
                HeightRequest="50"
                CornerRadius="22"
                BackgroundColor="#6970E6"
                TextColor="White"
                FontAttributes="Bold"/>

    </Grid>
</ContentPage>